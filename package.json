{
  "name": "screen-time-tracker",
  "version": "1.0.0",
  "description": "桌面端屏幕使用时间统计工具",
  "main": "electron/main.js",
  "author": "Screen Time Tracker",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "better-sqlite3": "^11.3.0",
    "chart.js": "^4.4.4",
    "vue": "^3.5.8",
    "vue-chartjs": "^5.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.screentime.tracker",
    "productName": "ScreenTimeTracker",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
